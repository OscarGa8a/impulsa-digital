---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { getWhatsAppLink } from '../../data/constants';
---

<section id="contacto" class="py-20 lg:py-24 bg-[var(--color-accent)]">
  <div class="container">
    <div class="flex flex-col items-center gap-8 text-center max-w-4xl mx-auto">
      <!-- Label -->
      <Badge class="bg-white/20 text-white">
        <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
        <span class="text-xs font-medium text-white tracking-wide">
          Empezá hoy
        </span>
      </Badge>
      
      <!-- H2 grande -->
      <h2 
        class="text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight"
        style="font-family: var(--font-heading);"
      >
        ¿Listo para hacer crecer tu negocio?
      </h2>
      
      <!-- Subtítulo -->
      <p class="text-lg md:text-xl text-white/90 max-w-2xl">
        Hablemos de tu proyecto. Sin compromisos, sin rodeos. Solo soluciones reales para tu negocio.
      </p>
      
      <!-- Botones -->
      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <Button 
          href={getWhatsAppLink()} 
          size="lg" 
          class="bg-white text-[var(--color-accent)] hover:bg-white/90"
        >
          Hablemos por WhatsApp
        </Button>
        <Button 
          href="mailto:hola@impulsadigital.co" 
          size="lg" 
          class="bg-white/10 text-white hover:bg-white/20 backdrop-blur-sm"
        >
          Enviar un email
        </Button>
      </div>
    </div>
  </div>
</section>
