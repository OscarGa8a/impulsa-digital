---
import Badge from '../ui/Badge.astro';
import TestimonialCard from '../ui/TestimonialCard.astro';
import { testimonials } from '../../data/testimonials';
---

<section id="testimonios" class="py-20 lg:py-24 bg-[var(--color-bg-secondary)]">
  <div class="container">
    <!-- Header -->
    <div class="flex flex-col items-center gap-4 mb-12 text-center">
      <Badge>
        Testimonios
      </Badge>
      <h2 
        class="text-3xl md:text-4xl font-bold text-[var(--color-text-primary)]"
        style="font-family: var(--font-heading);"
      >
        Lo que dicen nuestros clientes
      </h2>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl">
        Historias reales de negocios que crecieron con nuestras soluciones digitales.
      </p>
    </div>
    
    <!-- Grid de TestimonialCards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map(testimonial => (
        <TestimonialCard
          name={testimonial.name}
          role={testimonial.role}
          initials={testimonial.initials}
          avatarColor={testimonial.avatarColor}
          quote={testimonial.quote}
          rating={testimonial.rating}
        />
      ))}
    </div>
  </div>
</section>
