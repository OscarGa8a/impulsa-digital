---
import Badge from './Badge.astro';
import Card from './Card.astro';

interface Props {
  number: string;
  icon: string;
  title: string;
  description: string;
  highlighted?: boolean;
}

const { number, icon, title, description, highlighted = false } = Astro.props;

// Mapeo de íconos de lucide
const icons = {
  'message-circle': `
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>
    </svg>
  `,
  'lightbulb': `
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/>
      <path d="M9 18h6"/>
      <path d="M10 22h4"/>
    </svg>
  `,
  'zap': `
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>
    </svg>
  `,
  'trophy': `
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
      <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
      <path d="M4 22h16"/>
      <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
      <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
      <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
    </svg>
  `,
};

const iconSvg = icons[icon as keyof typeof icons] || '';
---

<Card 
  class={`flex flex-col gap-5 transition-transform hover:scale-[1.02] ${
    highlighted 
      ? 'bg-[var(--color-accent)] text-white border-2 border-[var(--color-accent)]' 
      : ''
  }`}
>
  <!-- Badge con número + ícono (horizontal) -->
  <div class="flex items-center gap-3">
    <div 
      class={`inline-flex items-center justify-center w-10 h-10 rounded-full font-bold text-sm ${
        highlighted 
          ? 'bg-white/20 text-white' 
          : 'bg-[var(--color-accent-bg)] text-[var(--color-accent)]'
      }`}
    >
      {number}
    </div>
    <div 
      class={`inline-flex items-center justify-center w-10 h-10 rounded-lg ${
        highlighted 
          ? 'text-white' 
          : 'text-[var(--color-accent)]'
      }`}
      set:html={iconSvg}
    />
  </div>
  
  <!-- Título -->
  <h3 
    class={`text-xl font-bold ${
      highlighted 
        ? 'text-white' 
        : 'text-[var(--color-text-primary)]'
    }`}
    style="font-family: var(--font-heading);"
  >
    {title}
  </h3>
  
  <!-- Descripción -->
  <p 
    class={`text-sm leading-relaxed ${
      highlighted 
        ? 'text-white/90' 
        : 'text-[var(--color-text-secondary)]'
    }`}
  >
    {description}
  </p>
</Card>
