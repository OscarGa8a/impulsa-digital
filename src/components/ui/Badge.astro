---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={`inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--color-accent-bg)] ${className || ''}`}>
  <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></div>
  <span class="text-xs font-medium text-[var(--color-accent)] tracking-wide">
    <slot />
  </span>
</div>
