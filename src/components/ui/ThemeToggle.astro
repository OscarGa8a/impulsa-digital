---
// ThemeToggle detecta automáticamente la preferencia del sistema
// No necesita props porque el comportamiento es automático
---

<button
  id="theme-toggle"
  aria-label="Toggle theme"
  class="flex items-center justify-center w-11 h-11 rounded-lg bg-[var(--color-bg-card)] hover:bg-[var(--color-bg-secondary)] transition-colors"
>
  <!-- Ícono de Sol (visible en dark mode) -->
  <svg 
    id="sun-icon"
    class="w-5 h-5 hidden dark:block"
    xmlns="http://www.w3.org/2000/svg" 
    width="24" 
    height="24" 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2" 
    stroke-linecap="round" 
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2"/>
    <path d="M12 20v2"/>
    <path d="m4.93 4.93 1.41 1.41"/>
    <path d="m17.66 17.66 1.41 1.41"/>
    <path d="M2 12h2"/>
    <path d="M20 12h2"/>
    <path d="m6.34 17.66-1.41 1.41"/>
    <path d="m19.07 4.93-1.41 1.41"/>
  </svg>
  
  <!-- Ícono de Luna (visible en light mode) -->
  <svg 
    id="moon-icon"
    class="w-5 h-5 block dark:hidden"
    xmlns="http://www.w3.org/2000/svg" 
    width="24" 
    height="24" 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2" 
    stroke-linecap="round" 
    stroke-linejoin="round"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
  </svg>
</button>

<script>
  // Este script se ejecuta en el cliente
  const toggle = document.getElementById('theme-toggle');
  
  if (toggle) {
    toggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
    });
  }
</script>
