---
import Card from './Card.astro';

interface Props {
  name: string;
  role: string;
  initials: string;
  avatarColor: 'green' | 'blue' | 'orange';
  quote: string;
  rating: 5;
}

const { name, role, initials, avatarColor, quote, rating } = Astro.props;

// Mapeo de colores de avatar
const avatarColors = {
  green: '#4CAF50',
  blue: '#2196F3',
  orange: '#FF9800',
};

const bgColor = avatarColors[avatarColor];
---

<Card class="flex flex-col gap-5">
  <!-- Estrellas (rating) -->
  <div class="flex gap-1">
    {Array.from({ length: rating }).map(() => (
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="18" 
        height="18" 
        viewBox="0 0 24 24" 
        fill="#ff3b30" 
        stroke="none"
      >
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    ))}
  </div>
  
  <!-- Quote -->
  <blockquote class="text-base leading-relaxed text-[var(--color-text-primary)]">
    "{quote}"
  </blockquote>
  
  <!-- Avatar + Info -->
  <div class="flex items-center gap-3 pt-2">
    <!-- Avatar circular con iniciales -->
    <div 
      class="flex items-center justify-center w-12 h-12 rounded-full text-white font-bold text-sm"
      style={`background-color: ${bgColor};`}
    >
      {initials}
    </div>
    
    <!-- Nombre y rol -->
    <div class="flex flex-col">
      <div class="font-semibold text-[var(--color-text-primary)]">
        {name}
      </div>
      <div class="text-sm text-[var(--color-text-secondary)]">
        {role}
      </div>
    </div>
  </div>
</Card>
